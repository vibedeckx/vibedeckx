# Vibedeckx server environment — EXAMPLE (safe to commit)
#
# Copy this to the server (NOT into the repo) as the file referenced by
# EnvironmentFile= in the unit, e.g. /etc/vibedeckx/env, then fill in real values:
#
#   sudo install -m 600 -o vibedeckx -g vibedeckx deploy/vibedeckx.env.example /etc/vibedeckx/env
#   sudo nano /etc/vibedeckx/env
#
# Format is systemd EnvironmentFile (KEY=value), NOT a shell script:
#   - no `export`
#   - no quotes around values
#   - no variable expansion / command substitution

# Required by --auth (Clerk). Get these from your Clerk dashboard.
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Optional: TLS paths can live here instead of on the ExecStart line.
# If set, drop the matching --cert/--key/--client-ca flags from the unit.
# VIBEDECKX_TLS_CERT=/opt/vibedeckx/cf-origin.pem
# VIBEDECKX_TLS_KEY=/opt/vibedeckx/cf-origin.key
# VIBEDECKX_TLS_CLIENT_CA=/opt/vibedeckx/cloudflare-aop-ca.pem

# Optional: extra API-key auth layer (in addition to Clerk).
# VIBEDECKX_API_KEY=
