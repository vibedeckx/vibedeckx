# Vibedeckx Docker secrets — EXAMPLE (safe to commit).
# Copy to deploy/docker.env (gitignored) and fill in real values:
#     cp deploy/docker.env.example deploy/docker.env
#
# Format is docker env_file (KEY=value): no `export`, no quotes, no expansion.

# Required by --auth (Clerk).
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Optional: extra API-key auth layer.
# VIBEDECKX_API_KEY=

# Cross-remote MCP gateway — public base URL that remote workers reach THIS
# server at. Must be the Cloudflare domain used for reverse-connect, NOT the
# :8444 origin (the origin only accepts Cloudflare-fronted traffic via AOP).
# Set scheme+host only; the gateway appends /api/cross-remote-mcp itself.
# Leave unset to keep the cross-remote feature off.
# VIBEDECKX_PUBLIC_URL=https://app.example.com
